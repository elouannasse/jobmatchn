generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  password         String
  firstName        String
  lastName         String
  role             Role              @default(CANDIDATE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  candidateProfile CandidateProfile?
  recruiterProfile RecruiterProfile?

  @@map("users")
}

model CandidateProfile {
  id           String        @id @default(uuid())
  userId       String        @unique
  title        String?
  summary      String?
  location     String?
  skills       String[]
  linkedinUrl  String?
  cvUrl        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("candidate_profiles")
}

model RecruiterProfile {
  id             String     @id @default(uuid())
  userId         String     @unique
  companyId      String?
  isApproved     Boolean    @default(false)
  approvedAt     DateTime?
  rejectedReason String?
  phone          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  offers         JobOffer[]
  company        Company?   @relation(fields: [companyId], references: [id])
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recruiter_profiles")
}

model Company {
  id          String             @id @default(uuid())
  name        String
  logoUrl     String?
  description String?
  website     String?
  location    String?
  industry    String?
  size        String?
  recruiters  RecruiterProfile[]
  jobs        JobOffer[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@map("companies")
}

model JobOffer {
  id           String           @id @default(uuid())
  recruiterId  String
  companyId    String
  title        String
  description  String
  location     String
  contractType ContractType
  salaryMin    Int?
  salaryMax    Int?
  skills       String[]
  isPublished  Boolean          @default(false)
  approvalStatus JobApprovalStatus @default(PENDING)
  approvedAt     DateTime?
  rejectedReason String?
  approvedBy     String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  applications Application[]
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recruiter    RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  @@map("job_offers")
}

model Application {
  id          String            @id @default(uuid())
  candidateId String
  jobOfferId  String
  status      ApplicationStatus @default(PENDING)
  coverLetter String?
  score            Int?
  interviewDate    DateTime?
  interviewMessage String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  candidate   CandidateProfile  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobOffer    JobOffer          @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobOfferId])
  @@map("applications")
}

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

enum ContractType {
  CDI
  CDD
  INTERNSHIP
  FREELANCE
  PART_TIME
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  INTERVIEW
  ACCEPTED
  REJECTED
}

enum JobApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_resets")
}
